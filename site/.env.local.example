# Local development convenience. Run at the root so http://localhost:3010/
# serves the homepage, instead of /harpenden-ai/.
# Vercel production should NOT set this - basePath defaults to /harpenden-ai.
HARPENDEN_BASE_PATH=

# Tenant selector. Each Vercel deployment sets this to pick the
# active place. Defaults to "harpenden" if unset.
NEXT_PUBLIC_PLACE_SLUG=harpenden
