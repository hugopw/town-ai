# Tenant selector. Each Vercel project sets this to pick the
# active place. Defaults to "harpenden" if unset.
NEXT_PUBLIC_PLACE_SLUG=harpenden

# Optional: only set this if a tenant is proxied behind a sub-path
# on a parent domain (e.g. ainightschool.org/harpenden-ai/). Leave
# unset for standalone tenant deployments.
# TOWN_AI_BASE_PATH=/harpenden-ai
